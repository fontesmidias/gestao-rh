# ============================================================
# Portal de Admissão Green House — copie para .env e preencha.
# O .env NUNCA é commitado (bloqueado no .gitignore).
# ============================================================

# --- Aplicação ---
ENVIRONMENT=production
SECRET_KEY=gere-uma-chave-longa-aleatoria
# URL pública usada nos links mágicos e e-mails.
# Modo IP:      http://SEU_IP:8090   |   Com domínio: https://admissao.seudominio.com.br
BASE_URL=http://localhost:8090

# --- Porta exposta do front (única porta publicada no modo IP) ---
FRONTEND_PORT=8090

# --- Domínio (apenas stacks traefik/certbot) ---
DOMAIN=admissao.seudominio.com.br
ACME_EMAIL=rh@greenhousedf.com.br

# --- Postgres ---
POSTGRES_USER=admissao
POSTGRES_PASSWORD=troque-me
POSTGRES_DB=admissao
DATABASE_URL=postgresql+psycopg://admissao:troque-me@db:5432/admissao

# --- Redis (fila de tarefas) ---
REDIS_URL=redis://redis:6379/0

# --- MinIO (arquivos) ---
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=troque-me
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=troque-me
MINIO_BUCKET=admissao
MINIO_SECURE=false

# --- SMTP (notificações e envio das fichas) ---
SMTP_HOST=smtp.seuprovedor.com
SMTP_PORT=587
SMTP_USER=rh@greenhousedf.com.br
SMTP_PASSWORD=troque-me
SMTP_FROM=rh@greenhousedf.com.br

# --- RH: admin inicial (criado no primeiro start se não houver usuários) ---
RH_ADMIN_EMAIL=rh@greenhousedf.com.br
RH_ADMIN_PASSWORD=troque-me
RH_SESSION_TTL_HOURS=12

# --- Regras de negócio ---
MAGIC_LINK_TTL_HOURS=72
OTP_TTL_MINUTES=10
# Expurgo de arquivos no MinIO após conclusão (LGPD + espaço em disco)
RETENTION_DAYS=90
